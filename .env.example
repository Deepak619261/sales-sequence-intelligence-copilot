# Sales Sequence Copilot - Environment Overrides
# Copy this file to '.env' and fill in your details

# System Settings
LOG_LEVEL=INFO

# Embedding Provider Settings ('sentence-transformers', 'gemini', 'cohere', or 'mock')
EMBEDDINGS_PROVIDER=sentence-transformers
EMBEDDINGS_DIMENSION=384

# Vector Store Settings ('local' or 'qdrant')
VECTORSTORE_TYPE=local

# Gemini API Key (Required for live 'gemini' provider)
GEMINI_API_KEY=your_gemini_api_key_here

# Cohere API Key (Required for live 'cohere' provider)
COHERE_API_KEY=your_cohere_api_key_here

# Qdrant Cloud Settings (Required for live 'qdrant' vector store)
QDRANT_URL=your_qdrant_cloud_url_here
QDRANT_API_KEY=your_qdrant_cloud_api_key_here

# Reranker Settings
RERANKER_ENABLED=true
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=10

# LLM Generator settings
LLM_PROVIDER=mock
LLM_MODEL_NAME=gemini-1.5-flash
